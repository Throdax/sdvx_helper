<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sdvxhelper.ui.controller.OcrReporterController"
            prefWidth="900" prefHeight="600">

    <top>
        <VBox>
            <HBox spacing="12" styleClass="toolbar-bar" alignment="CENTER_LEFT">
                <Button text="%button.ocr.open.folder" fx:id="btnOpenFolder" onAction="#onOpenFolder"/>
                <Button text="%button.ocr.prev"        fx:id="btnPrev"       onAction="#onPrev" disable="true"/>
                <Button text="%button.ocr.next"        fx:id="btnNext"       onAction="#onNext" disable="true"/>
                <Label fx:id="lblImageCount" text="0 / 0" styleClass="muted"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="%label.language" styleClass="muted"/>
                <ComboBox fx:id="cmbLanguage" styleClass="lang-combo"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <SplitPane dividerPositions="0.55">
            <!-- Left: image preview -->
            <VBox spacing="8">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <Label text="%label.ocr.preview" styleClass="sub-heading"/>
                <ImageView fx:id="imgPreview" fitWidth="480" fitHeight="360" preserveRatio="true"/>
                <Label text="%label.ocr.detected.hash" styleClass="muted"/>
                <TextField fx:id="txtHash" editable="false"/>
            </VBox>

            <!-- Right: song matching and registration -->
            <VBox spacing="8">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <Label text="OCR / Song Match" styleClass="sub-heading"/>
                <Label text="%label.ocr.ocr.title" styleClass="muted"/>
                <TextField fx:id="txtOcrTitle"/>
                <Label text="%label.ocr.song.title" styleClass="muted"/>
                <TextField fx:id="txtTitle"/>
                <Label text="%label.ocr.difficulty" styleClass="muted"/>
                <ComboBox fx:id="cmbDifficulty">
                    <items>
                        <javafx.collections.FXCollections fx:factory="observableArrayList">
                            <String fx:value="nov"/>
                            <String fx:value="adv"/>
                            <String fx:value="exh"/>
                            <String fx:value="mxm"/>
                            <String fx:value="inf"/>
                            <String fx:value="grv"/>
                            <String fx:value="hvn"/>
                            <String fx:value="vvd"/>
                            <String fx:value="xcd"/>
                        </javafx.collections.FXCollections>
                    </items>
                </ComboBox>
                <Separator/>
                <Button text="%button.ocr.register" fx:id="btnRegister" onAction="#onRegister"
                        styleClass="button-success"/>
                <Button text="%button.ocr.skip" fx:id="btnSkip" onAction="#onSkip"/>
                <Separator/>
                <Label text="%label.ocr.log" styleClass="muted"/>
                <TextArea fx:id="txtLog" prefRowCount="8" editable="false"
                          style="-fx-font-family: monospace;"/>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
