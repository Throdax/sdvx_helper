<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sdvxhelper.ui.controller.MainController"
            prefWidth="940" prefHeight="640">

    <top>
        <VBox>
            <!-- Menu bar -->
            <MenuBar styleClass="menu-bar">
                <Menu text="%menu.file">
                    <MenuItem text="%menu.file.settings"    fx:id="menuSettings"    onAction="#onSettings"/>
                    <MenuItem text="%menu.file.obs"         fx:id="menuObsControl"  onAction="#onObsControl"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="%menu.file.exit"        onAction="#onExit"/>
                </Menu>
                <Menu text="%menu.tools">
                    <MenuItem text="%menu.tools.google.drive" fx:id="menuGoogleDrive" onAction="#onGoogleDrive"/>
                    <MenuItem text="%menu.tools.webhooks"     fx:id="menuWebhooks"    onAction="#onWebhooks"/>
                </Menu>
            </MenuBar>

            <!-- Status / indicator bar -->
            <HBox spacing="10" styleClass="toolbar-bar" alignment="CENTER_LEFT">
                <Label text="%label.main.obs" styleClass="muted"/>
                <Label fx:id="lblObsStatus" text="%label.main.obs.disconnected" styleClass="obs-disconnected"/>
                <Label text="  |  " styleClass="muted"/>
                <Label text="%label.main.vf" styleClass="muted"/>
                <Label fx:id="lblTotalVf" text="0.000" styleClass="highlight-label"/>
                <Label text="  |  " styleClass="muted"/>
                <Label text="%label.main.plays" styleClass="muted"/>
                <Label fx:id="lblPlayCount" text="0" styleClass="value-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="%label.language" styleClass="muted"/>
                <ComboBox fx:id="cmbLanguage" styleClass="lang-combo"/>
            </HBox>

            <!-- F1-F3 reserved keys hint bar -->
            <HBox spacing="20" styleClass="shortcut-hint-bar" alignment="CENTER_LEFT">
                <Label text="F1: " styleClass="shortcut-hint"/>
                <Label text="%text.main.shortcut.f1" styleClass="shortcut-hint"/>
                <Label text="   F2: " styleClass="shortcut-hint"/>
                <Label text="%text.main.shortcut.f2" styleClass="shortcut-hint"/>
                <Label text="   F3: " styleClass="shortcut-hint"/>
                <Label text="%text.main.shortcut.f3" styleClass="shortcut-hint"/>
            </HBox>

            <!-- F4-F9 function icon toolbar -->
            <HBox spacing="4" styleClass="toolbar-bar" alignment="CENTER_LEFT">
                <Button fx:id="btnF4" styleClass="icon-button" onAction="#onSaveVolforce">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
                            <image><Image url="/images/function_volforce.png"/></image>
                        </ImageView>
                    </graphic>
                    <tooltip><Tooltip text="F4: %text.main.shortcut.f4"/></tooltip>
                </Button>
                <Button fx:id="btnF5" styleClass="icon-button" onAction="#onSaveSummary">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
                            <image><Image url="/images/function_summary.png"/></image>
                        </ImageView>
                    </graphic>
                    <tooltip><Tooltip text="F5: %text.main.shortcut.f5"/></tooltip>
                </Button>
                <Button fx:id="btnF6" styleClass="icon-button" onAction="#onSaveResult">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
                            <image><Image url="/images/function_capture.png"/></image>
                        </ImageView>
                    </graphic>
                    <tooltip><Tooltip text="F6: %text.main.shortcut.f6"/></tooltip>
                </Button>
                <Button fx:id="btnF7" styleClass="icon-button" onAction="#onImportScore">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
                            <image><Image url="/images/function_discord.png"/></image>
                        </ImageView>
                    </graphic>
                    <tooltip><Tooltip text="F7: %text.main.shortcut.f7"/></tooltip>
                </Button>
                <Button fx:id="btnF8" styleClass="icon-button" onAction="#onUpdateRival">
                    <graphic>
                        <ImageView fitWidth="24" fitHeight="24" preserveRatio="true">
                            <image><Image url="/images/function_discord.png"/></image>
                        </ImageView>
                    </graphic>
                    <tooltip><Tooltip text="F8: %text.main.shortcut.f8"/></tooltip>
                </Button>
                <Button fx:id="btnF9" styleClass="icon-button" onAction="#onStartRta">
                    <tooltip><Tooltip text="F9: %text.main.shortcut.f9"/></tooltip>
                    <padding><Insets top="4" right="8" bottom="4" left="8"/></padding>
                </Button>
            </HBox>
        </VBox>
    </top>

    <!-- Centre: split panel -->
    <center>
        <SplitPane dividerPositions="0.42">
            <!-- Left: current song detection panel -->
            <VBox spacing="8">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <Label text="%label.main.current.song" styleClass="section-heading"/>
                <GridPane hgap="8" vgap="6">
                    <Label text="%label.main.title"      GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="muted"/>
                    <Label fx:id="lblTitle"              GridPane.columnIndex="1" GridPane.rowIndex="0" text="-" styleClass="value-label"/>
                    <Label text="%label.main.diff"       GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="muted"/>
                    <Label fx:id="lblDiff"               GridPane.columnIndex="1" GridPane.rowIndex="1" text="-" styleClass="value-label"/>
                    <Label text="%label.main.level"      GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="muted"/>
                    <Label fx:id="lblLevel"              GridPane.columnIndex="1" GridPane.rowIndex="2" text="-" styleClass="value-label"/>
                    <Label text="%label.main.best.score" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="muted"/>
                    <Label fx:id="lblBest"               GridPane.columnIndex="1" GridPane.rowIndex="3" text="-" styleClass="value-label"/>
                    <Label text="%label.main.best.lamp"  GridPane.columnIndex="0" GridPane.rowIndex="4" styleClass="muted"/>
                    <Label fx:id="lblLamp"               GridPane.columnIndex="1" GridPane.rowIndex="4" text="-" styleClass="value-label"/>
                    <Label text="%label.main.best.vf"    GridPane.columnIndex="0" GridPane.rowIndex="5" styleClass="muted"/>
                    <Label fx:id="lblVf"                 GridPane.columnIndex="1" GridPane.rowIndex="5" text="-" styleClass="value-label"/>
                </GridPane>
                <Separator/>
                <Label text="%label.main.detection.state" styleClass="sub-heading"/>
                <Label fx:id="lblDetectMode" text="INIT" styleClass="status-label"/>
                <HBox spacing="8">
                    <Button fx:id="btnStartStop" text="%button.main.start.detection"
                            onAction="#onStartStop" styleClass="button-success"/>
                    <Button fx:id="btnPopPlay"   text="%button.main.undo.play"
                            onAction="#onPopPlay"  styleClass="button-danger"/>
                </HBox>
            </VBox>

            <!-- Right: session log -->
            <VBox spacing="8">
                <padding><Insets top="12" right="12" bottom="12" left="12"/></padding>
                <Label text="%label.main.session.log" styleClass="section-heading"/>
                <TableView fx:id="tblSessionLog" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLogTitle" text="%table.header.title"      prefWidth="220"/>
                        <TableColumn fx:id="colLogDiff"  text="%table.header.difficulty" prefWidth="60"/>
                        <TableColumn fx:id="colLogScore" text="%table.header.score"      prefWidth="90"/>
                        <TableColumn fx:id="colLogLamp"  text="%table.header.lamp"       prefWidth="60"/>
                        <TableColumn fx:id="colLogDate"  text="%table.header.date"       prefWidth="120"/>
                    </columns>
                </TableView>
                <TextArea fx:id="txtOutput" prefRowCount="10" editable="false"
                          style="-fx-font-family: monospace;"/>
            </VBox>
        </SplitPane>
    </center>

    <!-- Bottom: status bar -->
    <bottom>
        <HBox styleClass="toolbar-bar">
            <Label fx:id="lblStatus" text="Ready" styleClass="status-label"/>
        </HBox>
    </bottom>
</BorderPane>
