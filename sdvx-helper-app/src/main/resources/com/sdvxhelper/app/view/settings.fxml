<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.sdvxhelper.app.controller.SettingsController"
            fitToWidth="true" prefWidth="720" prefHeight="620">

    <VBox spacing="8">
        <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

        <!-- General group -->
        <TitledPane text="%label.settings.general" collapsible="true" expanded="true">
            <GridPane hgap="12" vgap="8">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <columnConstraints>
                    <ColumnConstraints minWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="%label.settings.player.name" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="muted"/>
                <TextField fx:id="txtPlayerName"          GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <CheckBox fx:id="chkAutoUpdate" text="%label.settings.auto.update"
                          GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2"/>
                <CheckBox fx:id="chkIgnoreRankD" text="%label.settings.ignore.rankd"
                          GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2"/>
                <CheckBox fx:id="chkClipLxly" text="%label.settings.clip.lxly"
                          GridPane.columnIndex="0" GridPane.rowIndex="3" GridPane.columnSpan="2"/>
                <CheckBox fx:id="chkAlwaysUpdateVf" text="%label.settings.always.update.vf"
                          GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2"/>
            </GridPane>
        </TitledPane>

        <!-- OBS group -->
        <TitledPane text="%label.settings.obs" collapsible="true" expanded="true">
            <GridPane hgap="12" vgap="8">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <columnConstraints>
                    <ColumnConstraints minWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="%label.settings.obs.host"     GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="muted"/>
                <TextField fx:id="txtObsHost"              GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="%label.settings.obs.port"     GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="muted"/>
                <TextField fx:id="txtObsPort"              GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="%label.settings.obs.password" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="muted"/>
                <PasswordField fx:id="txtObsPassword"      GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                <Label text="%label.settings.obs.source"   GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="muted"/>
                <TextField fx:id="txtObsSource"            GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            </GridPane>
        </TitledPane>

        <!-- Detection / auto-save group -->
        <TitledPane text="%label.settings.detection" collapsible="true" expanded="true">
            <GridPane hgap="12" vgap="8">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <columnConstraints>
                    <ColumnConstraints minWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="%label.settings.detect.wait"  GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="muted"/>
                <TextField fx:id="txtDetectWait"           GridPane.columnIndex="1" GridPane.rowIndex="0" prefColumnCount="10" maxWidth="120"/>

                <Label text="%label.settings.autosave.dir" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="muted"/>
                <HBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <TextField fx:id="txtAutosaveDir" prefColumnCount="100" HBox.hgrow="ALWAYS"/>
                    <Button text="%button.settings.browse" onAction="#onBrowseAutosaveDir"/>
                </HBox>

                <Label text="%label.settings.autosave.int" GridPane.columnIndex="0" GridPane.rowIndex="2" styleClass="muted"/>
                <TextField fx:id="txtAutosaveInterval"     GridPane.columnIndex="1" GridPane.rowIndex="2" prefColumnCount="10" maxWidth="120"/>

                <Label text="%label.settings.autosave.prewait" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="muted"/>
                <TextField fx:id="txtAutosavePrewait" GridPane.columnIndex="1" GridPane.rowIndex="3" prefColumnCount="10" maxWidth="120"/>

                <CheckBox fx:id="chkAutosaveAlways" text="%label.settings.autosave.always"
                          GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2"/>
                <CheckBox fx:id="chkSaveJacketImg" text="%label.settings.save.jacket"
                          GridPane.columnIndex="0" GridPane.rowIndex="5" GridPane.columnSpan="2"/>
            </GridPane>
        </TitledPane>

        <!-- Discord / RTA group -->
        <TitledPane text="%label.settings.integrations" collapsible="true" expanded="true">
            <GridPane hgap="12" vgap="8">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <columnConstraints>
                    <ColumnConstraints minWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <CheckBox fx:id="chkDiscordEnable" text="%label.settings.discord.enable"
                          GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="2"/>

                <Label text="%label.settings.rta.target.vf" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="muted"/>
                <TextField fx:id="txtRtaTargetVf" GridPane.columnIndex="1" GridPane.rowIndex="1" prefColumnCount="10" maxWidth="120"/>
            </GridPane>
        </TitledPane>

        <!-- Webhooks group -->
        <TitledPane text="%label.settings.webhooks" collapsible="true" expanded="false">
            <GridPane hgap="12" vgap="8">
                <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>
                <columnConstraints>
                    <ColumnConstraints minWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="%label.settings.webhook.name" GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="muted"/>
                <TextField fx:id="txtWebhookName"          GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                <Label text="%label.settings.webhook.url"  GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="muted"/>
                <TextField fx:id="txtWebhookUrl"           GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="(Multiple webhooks managed via the Webhooks menu)"
                       GridPane.columnIndex="0" GridPane.rowIndex="2" GridPane.columnSpan="2" styleClass="muted"/>
            </GridPane>
        </TitledPane>

    </VBox>
</ScrollPane>
